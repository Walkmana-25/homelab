{
	"name": "Dev",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"redhat.ansible",
				"redhat.vscode-yaml",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"Ryosuke-Asano.zai-vscode-chat",
				"RooVeterinaryInc.roo-cline"
			],
			"settings": {
				"ansible.python.interpreterPath": "/usr/bin/python3",
				"ansible.ansible.path": "/usr/local/bin/ansible",
				"ansible.validation.lint.enabled": true,
				"yaml.schemas": {
					"kubernetes": "*.yaml"
				}
			}
		}
	},
	"remoteUser": "vscode",
	"postCreateCommand": "cd ansible && make install-lint && make install-requirements && cd ../argocd && make check",
	"workspaceFolder": "/workspaces/homelab",
	"mounts": [
		"source=${localEnv:HOME}/.kube,target=/home/vscode/.kube,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.gemini,target=/home/vscode/.gemini,type=bind,consistency=cached"
	]
}
